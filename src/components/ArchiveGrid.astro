---
import type { MemorialRecord } from '../data/memorials';
import { withBase } from '../utils/urls';
import MemorialCard from './MemorialCard.astro';

interface Props {
  items: MemorialRecord[];
  heading?: string;
  showEpitaph?: boolean;
  filterable?: boolean;
}

const { items, heading = 'Filed records', showEpitaph = true, filterable = false } = Astro.props;
const filters = [
  { value: 'all', label: 'All records' },
  { value: 'Product', label: 'Products' },
  { value: 'Feature', label: 'Features & tools' },
  { value: 'API', label: 'APIs' },
  { value: 'Integration', label: 'Integrations' },
];
---

<section class="archive-section site-shell" aria-labelledby="records-heading" data-filterable-archive={filterable || undefined}>
  <header>
    <h2 id="records-heading">{heading}</h2>
    <span>{items.length} total</span>
  </header>
  {filterable && (
    <nav class="filters" aria-label="Filter cemetery records">
      {filters.map((filter) => (
        <a data-filter={filter.value} href={filter.value === 'all' ? withBase('graveyard/') : withBase(`graveyard/?category=${filter.value}`)}>
          {filter.label}
        </a>
      ))}
    </nav>
  )}
  <div class="archive-grid">
    {items.map((item) => (
      <div class="archive-item" data-category={item.category === 'Tool' ? 'Feature' : item.category}>
        <MemorialCard item={item} showEpitaph={showEpitaph} />
      </div>
    ))}
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-filterable-archive]').forEach((archive) => {
    const requested = new URLSearchParams(window.location.search).get('category') ?? 'all';
    const allowed = new Set(['all', 'Product', 'Feature', 'API', 'Integration']);
    const active = allowed.has(requested) ? requested : 'all';

    archive.querySelectorAll<HTMLElement>('[data-category]').forEach((item) => {
      item.hidden = active !== 'all' && item.dataset.category !== active;
    });
    archive.querySelectorAll<HTMLAnchorElement>('[data-filter]').forEach((link) => {
      const isActive = link.dataset.filter === active;
      link.classList.toggle('active', isActive);
      if (isActive) link.setAttribute('aria-current', 'page');
    });
  });
</script>

<style>
  .archive-section { padding-block: 46px 64px; }
  header { display: flex; align-items: baseline; justify-content: space-between; gap: 20px; margin-bottom: 17px; }
  h2 { margin: 0; font-size: 20px; font-weight: 650; letter-spacing: -.025em; }
  header span { color: var(--muted); font-size: 10px; letter-spacing: .08em; text-transform: uppercase; }
  .filters { display: flex; flex-wrap: wrap; gap: 7px; margin: -3px 0 18px; }
  .filters a { padding: 7px 10px; border: 1px solid var(--line); border-radius: 5px; color: var(--muted); font-size: 10px; text-decoration: none; transition: border-color .2s ease, color .2s ease, background .2s ease; }
  .filters a:hover { border-color: #50606c; color: var(--text); }
  .filters a.active { border-color: var(--green-deep); background: rgba(80, 223, 138, .08); color: var(--green); }
  .archive-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .archive-item { min-width: 0; }
  .archive-item[hidden] { display: none; }
  .archive-item :global(.memorial-card) { height: 100%; }
  @media (max-width: 800px) { .archive-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .archive-grid { grid-template-columns: 1fr; } }
</style>
