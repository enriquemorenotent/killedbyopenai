---
import TombstoneIcon from './TombstoneIcon.astro';
import { withBase } from '../utils/urls';

interface Props {
  eyebrow: string;
  title: string;
  summary: string;
  count: number;
  countLabel?: string;
  tone?: 'green' | 'yellow' | 'purple' | 'blue' | 'red' | 'pink';
}

const { eyebrow, title, summary, count, countLabel = 'records', tone = 'green' } = Astro.props;
const heroImage = withBase('images/openai-tombstone-hero.png');
---

<section class:list={['archive-hero', `tone-${tone}`]} aria-labelledby="archive-title">
  <div class="archive-inner site-shell">
    <div class="archive-copy">
      <p class="eyebrow"><TombstoneIcon size={14} /> {eyebrow}</p>
      <h1 id="archive-title">{title}</h1>
      <p class="summary">{summary}</p>
      <p class="record-count"><strong>{count}</strong> {countLabel}</p>
    </div>
    <div class="stone-crop" aria-hidden="true">
      <img src={heroImage} alt="" width="1680" height="968" />
    </div>
  </div>
</section>

<style>
  .archive-hero { overflow: hidden; border-bottom: 1px solid var(--line-soft); background: #060b10; }
  .archive-inner { position: relative; display: flex; min-height: 300px; align-items: center; }
  .archive-copy { position: relative; z-index: 2; width: 54%; padding-block: 52px; }
  .eyebrow { display: flex; gap: 8px; align-items: center; margin: 0 0 15px; color: var(--tone); font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; }
  h1 { max-width: 680px; margin: 0; font-size: clamp(48px, 6vw, 74px); font-weight: 680; line-height: .95; letter-spacing: -.055em; }
  .summary { max-width: 510px; margin: 18px 0 0; color: #aeb7bf; font-size: 14px; line-height: 1.55; }
  .record-count { margin: 24px 0 0; color: var(--muted); font-size: 10px; letter-spacing: .07em; text-transform: uppercase; }
  .record-count strong { margin-right: 5px; color: var(--tone); font-size: 20px; letter-spacing: 0; }
  .stone-crop { position: absolute; z-index: 0; top: 0; right: -120px; bottom: 0; width: 69%; }
  .stone-crop::after { position: absolute; inset: 0; background: linear-gradient(90deg, #060b10 0%, rgba(6, 11, 16, .9) 20%, transparent 57%, #060b10 100%); content: ''; }
  .stone-crop img { width: 100%; height: 100%; object-fit: cover; object-position: 58% 49%; opacity: .78; }
  @media (max-width: 720px) {
    .archive-inner { min-height: 420px; align-items: end; }
    .archive-copy { width: 100%; padding-block: 175px 38px; }
    .stone-crop { right: -95px; bottom: auto; width: calc(100% + 130px); height: 290px; }
    .stone-crop::after { background: linear-gradient(180deg, transparent 0%, rgba(6, 11, 16, .1) 35%, #060b10 100%); }
    .stone-crop img { object-position: 57% 45%; }
    h1 { font-size: clamp(44px, 14vw, 65px); }
    .summary { max-width: 440px; font-size: 13px; }
  }
</style>
